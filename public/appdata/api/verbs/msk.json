              "21/64"
            ]
          },
          {
            "turoyo": "huwe w-i=aṯto a=tre kilín b-u=ḥabis msike ‘",
            "translations": [
              "Er und seine Gemahlin sind beide gefangen im Kerker"
            ],
            "references": [
              "24/238"
            ]
          }
        ],
        "Infinitive": [
          {
            "turoyo": "bəṯṯər mədə-k-mayṣi u=admo, u=msokaṯṯe šmənto k-foyəš băṣīṭ",
            "translations": [
              "wenn sie (die Wanzen) das Blut erst gesaugt haben, dann ist es ziemlich einfach, sie zu fangen"
            ],
            "references": [
              "123",
              "1/25"
            ]
          }
        ],
        "Nomen Patiens": [
          {
            "turoyo": "mawfaqle qayṣ d-kət-we b-u=ḥăbīs msikoye, marfalle",
            "translations": [
              "er liess alle Eingekerkerten, so viele ihrer im Gefängniss waren, heraus und setzte sie in Freiheit"
