            "translations": [
              "‘Ehe er aber unter die Packsättel schlüpfte, hatte er fünfundzwanzig von den Rassestuten [seines Vaters] gefangen’; 29/457"
            ],
            "references": []
          }
        ],
        "Infectum": [
          {
            "turoyo": "kīt zlām b-u=făṣāl-ano gabayna, lo=k-məqṭəl w lo=k-məmsək",
            "translations": [
              "es ist ein Mann von der und der Art bei uns; der lässt sich weder tödten noch fangen"
            ],
            "references": [
              "129",
              "prs 31/8",
              "prs 201/23"
            ]
          }
        ],
        "Infectum-wa": [
          {
