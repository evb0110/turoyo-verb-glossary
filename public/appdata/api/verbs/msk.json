              "der Fuchs hat ihn hineingeworfen?"
            ],
            "references": [
              "120",
              "prs 248/36"
            ]
          }
        ],
        "Participle_Passive": [
          {
            "turoyo": "hani šet=əšne ono msiko",
            "translations": [
              "sechs Jahre schon sitze ich gefangen"
            ],
            "references": [
