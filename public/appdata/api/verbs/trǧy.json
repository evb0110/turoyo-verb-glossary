            "references": [
              "805",
              "62/82"
            ]
          },
          {
            "turoyo": "mətraǧalle mene ġálabe, ummi «k-ubʕina d-hat howat-lan qašo»",
            "translations": [],
            "references": []
          },
          {
            "turoyo": "‘Sie baten ihn sehr dringend:",
            "translations": [
              "Wir möchten, daß du bei uns Pfarrer wirst"
            ],
            "references": []
          }
        ],
        "Infectum": [
          {
            "turoyo": "aq=qadiš-ani g-mətraǧən l-u=aloh-aṯṯe, w hənnək masʔūl-ne b-i=tərt-aṯi d-u=faqiro",
            "translations": [
              "die Heiligen bitten ihren Gott, und sie sind verantwortlich für die Kuh des Armen"
            ],
            "references": [
              "805"
            ]
          },
          {
            "turoyo": "-806; 90/11; balki hənnək mətraǧən m-aloho d-oba-lxu naʕimo mede",
            "translations": [
              "‘Perhaps, they will ask God to give you a child’; 44/119"
            ],
            "references": []
          }
        ],
        "Imperative": [
          {
            "turoyo": "izúx ḥaláq bəṯr u=abro d-u=šulṭono, w mətraǧí mine, balki ʕofe-lux",
            "translations": [
              "laufe dem Sohne des Sultans nach und bitte ihn! Vielleicht wird er dir verzeihen"
            ],
            "references": [
              "806",
              "64/59"
