        "source_root": "ṭmm",
        "reference": "SL 536",
        "meaning": "to lock, shut up"
      }
    ]
  },
  "cross_reference": null,
  "stems": [
    {
      "forms": [
        "ṭəmle",
        "ṭoyəm"
      ],
      "conjugations": {
        "Preterit": [
          {
            "turoyo": "maḥatle riše, u=laly-awo lə=daməx, ʕayne lə=ṭimi",
            "translations": [
              "er legt sich hin, schläft aber die ganze Nacht nicht; die Augen wollen ihm nicht zufallen"
            ],
            "references": [
              "531",
              "78/34"
            ]
          }
        ],
        "Infectum": [
          {
            "turoyo": "ko-ṭomno ʕayni ṭomanno ruḥi bayn at=turaškat k-omanno: xudewo d-ʕayne lə=midoqo aʕli",
            "translations": [
              "wenn ich die Augen schliesse und mich im Gestrüpp verkrieche, Herr Gott! dass ja sein Auge nicht auf mich fällt"
            ],
            "references": [
              "522",
              "67/134"
            ]
          },
          {
            "turoyo": "i=naqla d-ko-ṭoyámnan-ne ko-ḥozeno u=med-ano",
            "translations": [
              "‘wenn ich (die Augen) verschliess, sah ich diese Szene’;"
            ],
            "references": [
              "LB 152"
            ]
          }
        ],
        "Imperative": [
          {
            "turoyo": "ṭum u=šalfo",
            "translations": [
              "klapp das Messer zu"
            ],
            "references": [
              "526"
            ]
          },
          {
            "turoyo": "ṭum ʕaynux ftáḥ-ene",
            "translations": [
              "schliess die Augen und mach sie wieder auf"
            ],
            "references": [
              "526",
              "73/400"
            ]
          }
        ],
        "Participle_Passive": [
          {
            "turoyo": "ono ʕayni ṭime taḥt i=arʕo",
            "translations": [
              "ich war unter der Erde mit verschlossenen Augen"
            ],
            "references": [
              "LB 148"
            ]
          }
        ],
        "Infinitive": [
          {
            "turoyo": "ono hawxa ʕayni ṭime w b-u=ṭyomo zatan, ṭime w ftiḥe ḥa-yo",
            "translations": [
              "‘nur meine Augen waren so geschlossen, und während ich so meine Augen geschlossen hielt, - es gab sowieso keinen Unterschied, ob die Augen nun geschlossen oder geöffnet waren’;"
            ],
            "references": [
              "LB 152"
