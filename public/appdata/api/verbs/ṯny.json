              "489",
              "29/346"
            ]
          },
          {
            "turoyo": "ko-mwalwəl, k-moḥe ʕal ṣadre, k-omər: «aḥuni, mvayəʕ!» ‘",
            "translations": [],
            "references": []
          },
          {
            "turoyo": "Er jammerte, schlug sich an die Brust und sprach:",
            "translations": [
              "Mein Bruder ist verloren gegangen"
            ],
            "references": [
              "24/281"
            ]
          },
          {
            "turoyo": "[MT]; uno, kət-wo-li ṭaṣe, mvayʕo",
            "translations": [
              "‘Ich hatte eine Schale, die ist verloren gegangen"
            ],
            "references": [
              "25/17"
            ]
          },
          {
            "turoyo": "ʕal baxti mvayʕono",
            "translations": [
              "‘Bei meiner Ehre, ich habe mich verirrt’; 26/148"
            ],
            "references": []
          }
        ],
        "Infectum": [
          {
            "turoyo": "bas aġlab d-am=məsken-ani lo=k-mitaniḥi, w kə-mvayʕi ʕaynoṯayye",
            "translations": [
              "aber die meisten dieser armen Menschen sind unheilbar und verlieren ihr Augen(licht) (für immer)"
            ],
            "references": [
              "3/27"
            ]
          }
        ],
        "Participle_Passive": [
          {
            "turoyo": ") mede-ste lo=k-foyəš mvayʕo",
            "translations": [
              "nichts bleibt verborgen"
            ],
            "references": [
              "489",
              "27/36"
            ]
          },
          {
            "turoyo": "zlam hov d-lo qarʕo lo ʕayno lo dukṯo mene, kule mvayʕo b-u=sawk-ayḏe",
            "translations": [
