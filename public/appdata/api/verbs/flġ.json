  "stems": [
    {
      "forms": [
        "fləġle",
        "foləġ"
      ],
      "conjugations": {
        "Preterit": [
          {
            "turoyo": "azzǝ́n l-u=bayto, fləġġe ak=kallat d-gnuwwe",
            "translations": [
              "sie gingen nach Hause und teilten dort das gestohlene Geld"
            ],
            "references": [
              "69",
              "prs 112/36"
            ]
          },
          {
            "turoyo": "ay=yiruṯe, d-ʕArəf Paša fləġġe u=qunāġ-ano ʕal ḥḏoḏe, w sǝ́m-wo-lle kmo=aparṭəmānat",
            "translations": [
              "die Erben des Arifi Pascha hatten diese Villa unter sich aufgeteilt und einige Mietswohnungen daraus gemacht"
            ],
            "references": [
              "2/57"
            ]
          },
          {
            "turoyo": "yabo, uno fləġli ak=kallāt-ani kulle ʕal-am=miṯe. kul miṯo qayəṯ-le ʕasro=kallāt",
            "translations": [
              "‘Mensch! Ich habe doch das ganze Geld unter die Toten verteilt. Auf jeden Toten kommen zehn Para’;"
            ],
            "references": [
              "25/65"
            ]
          }
        ],
        "Infectum": [
          {
            "turoyo": "u=kallat d-kīt ənkān ḥalāl w kān ḥărām k-məfləġ m-fəlgo",
            "translations": [
              "das Geld, welches da ist, mag es nun gerecht oder ungerecht erworben sein, soll in zwei gleiche Hälften geteilt werden"
            ],
            "references": [
              "129",
              "prs 225/37"
            ]
          },
          {
            "turoyo": "dawmo lə-k-məfloġo ḥḏo-yo",
            "translations": [
              "er ist nur ein Baum und nicht trennbar"
            ],
            "references": [
              "DD 391/6"
            ]
          }
        ],
        "Infinitive": [
          {
            "turoyo": "m-ayko yalifət u=floġ-ano?",
            "translations": [
              "woher hast du diese Art des Teilens gelernt?"
            ],
            "references": [
              "123",
              "prs 208/34"
            ]
          }
        ]
      },
