          {
            "turoyo": "mašəġle iḏe w-foṯe",
            "translations": [
              "er wusch sich Hände und Gesicht"
            ],
            "references": [
              "537",
              "60/104"
            ]
          },
          {
            "turoyo": "hul d-mašəġla iḏa; bəṯṯər me-d-matəmla u=layš-ayḏa",
            "translations": [
              "als sie mit dem Teig fertig war, wusch sie sich die Hände"
