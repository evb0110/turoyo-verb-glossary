            "references": [
              "538",
              "78/190"
            ]
          },
          {
            "turoyo": "mašəġġe arʕe d-as=sefoqe",
            "translations": [
              "sie putzten den Boden der Schüsseln blank"
            ],
            "references": [
              "539",
              "44/63"
            ]
          },
          {
            "turoyo": "mašəġli aǧ=ǧurḥe b-am=maye d-u=oksižan, manḏ̣əfili b-i=ispərto",
            "translations": [
              "ich wusch mir die Wunden mit Sauerstofflösung und sauberte sie mit Alkohol"
            ],
            "references": [
              "540",
              "7/11"
            ]
          },
          {
            "turoyo": "ʕdimo mašəġolan w-lo=naḏ̣ifo",
            "translations": [
              "‘er (der Teppich, f) war hin. Wir wuschen ihn, aber er wurde nicht sauber’;"
            ],
            "references": [
              "2/24"
            ]
          },
          {
            "turoyo": "ašər mašəġġe arʕe d-as=sefoqe",
            "translations": [
              "‘They certainly licked the bottom of the plates clean’ (i.e. they ate all the food up); 44/63"
            ],
            "references": []
          }
        ],
        "Infectum": [
          {
            "turoyo": "aǧ=ǧule mlawte k-lozəm d-mitašiġi",
            "translations": [
              "die schmutzige Wäsche muss gewaschen werden"
            ],
            "references": [
              "552"
            ]
          }
        ],
        "Infectum-wa": [
          {
            "turoyo": "ḥzeli ḥḏo ʕal u=baḥar, mašəġo-wa foṯa",
            "translations": [
              "ich sah eine am Meere, die wusch ihr Gesicht"
            ],
            "references": [
              "548",
              "prs 119/25"
            ]
          },
          {
            "turoyo": "əzzá-way-na, amṭí-way-na aḥ=ḥeṭe, maḥtí-way-na-nne b-lăgan rabo, mašiġí-way-na-nne tre=feme b-maye ǧamude",
            "translations": [
              "wir gingen und holten den Weizen, gaben ihn in einen grossen Bottich und wuschen ihn zweimal in kaltem Wasser"
            ],
            "references": []
          }
        ],
        "Imperative": [
          {
            "turoyo": "mgarwono foṯa, məlle-la l-u=ḥakimo, omər ašiġ-a b-u=baḥar, g-nayḥo",
            "translations": [
              "sie bekam Aussatz im Gesicht, und der Arzt hatte ihr befohlen, das Gesicht im Meere zu waschen, dann würde es gesund werden"
            ],
            "references": [
              "549",
              "prs 119/19"
            ]
          },
          {
            "turoyo": "mašiġu iḏe u foṯe",
            "translations": [
              "wäscht ihm Hände und Gesicht"
            ],
            "references": []
          }
        ],
        "Participle_Passive": [
          {
            "turoyo": "ko-ḥoyər: kaʔanno as=sefoqayḏe-ste mašiġe",
            "translations": [
              "da sah er, dass die Schüsseln (wie) abgewaschen waren"
            ],
            "references": [
              "552",
              "112/155"
            ]
          },
          {
            "turoyo": "maqalbí-way-na aḥ=ḥeṭe mašiġ-anək bayn am=maye raṯuḥe ʕal i=nuro",
            "translations": [
              "wir schütteten den gewaschenen Weizen in das kochende Wasser auf dem Feuer"
