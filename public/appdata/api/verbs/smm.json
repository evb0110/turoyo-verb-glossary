          {
            "turoyo": "ramḥəl g-msammo-li-ste",
            "translations": [
              "‘Dann wird sie morgen auch mich vergiften!’; 29/225;"
            ],
            "references": []
          },
          {
            "turoyo": "qoyəm amṭe səsyo w msamamle w msaməm ḥaṣe",
            "translations": [
              "er holte ein Pferd und vergiftete es, vergiftete seinen Rücken"
            ],
            "references": [
              "498",
              "115/283"
            ]
          }
        ],
        "Participle_Active": [
          {
            "turoyo": "maḥatla u=muklo qume, u=muklayḏe msamamla, w húla-le qaḥwe msammoniṯo",
            "translations": [
              "sie setzte ihm das Essen vor. Sie hatte sein Essen vergiftet, und sie gab ihm Kaffee, der vergiftend wirkte"
            ],
            "references": [
              "499",
              "60/242"
            ]
          }
        ],
        "Participle_Passive": [
          {
            "turoyo": "i=náqqa-yo d-oxe-le t-owe msammo, g-moyəṯ",
            "translations": [
              "wenn es (das Kätzchen m) frisst, und das Essen vergiftet ist, so wird es krepieren"
            ],
            "references": [
              "499",
              "99/114",
              "115/276"
            ]
          },
          {
            "turoyo": "lăšan ḥa d-maxləṣ m-u=bal-ano, ġēr m-u-šərboṭo d-a=syuġone, w m-u=ṣwoʕo d-at=taxtayat d-u=qṭoro b-sabġa msamamto, čara ḥreto layto",
            "translations": [
              "‘um sich von dieser Plage zu befreien, gibt es kein Mittel als die Wände zu verputzen und die Bretter der Decke mit vergifteter Farbe anzustreichen’;"
            ],
            "references": [
              "1/29"
            ]
          }
        ]
