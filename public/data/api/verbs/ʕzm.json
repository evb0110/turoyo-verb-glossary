              "99/112"
            ]
          }
        ],
        "Participle_Passive": [
          {
            "turoyo": "xayifo de qṭaʕʕe kul ḥa m-an=naʕimaṯṯe badle, w i=badlayḏax mawbela l-i=aṯto, w i=badlayḏi w i=qundərayḏi tavda, mawbe-lən l-u=gawro, w mal-le l-u=gawro-ste ṭr-oṯe l-gabi mʕázmo-yo",
            "translations": [
