      ],
      "conjugations": {
        "Preterit": [
          {
            "turoyo": "mḥayḏ̣alle i=barṯo d-ruḥe",
            "translations": [
              "(der König) machte seine Tochter bereit"
            ],
            "references": [
              "780",
              "61/353"
            ]
          },
          {
            "turoyo": "mḥaḏ̣alle-le l-u=babo, l-u=ḥəmyon-ayḏe, mḥaḏ̣alle-le arbʕi=gamle maṭʕəne",
            "translations": [
              "‘der Vater, sein Schwiegervater, hatte alles bereitgemacht. Er stellte vierzig beladene Kamele bereit"
            ],
            "references": [
              "24/133"
            ]
          },
          {
            "turoyo": "məd-hawi teni yawmo, mḥayḏ̣arre ruḥayye l-i=qale ḥatta d-nufqi-le",
            "translations": [
              "‘als der nächste Tag anbrach, machten sie sich bereit zum Kampf, um gegen ihn auszuziehen’;"
            ],
            "references": [
              "24/209"
            ]
          }
        ],
        "Infectum": [
          {
            "turoyo": "g-korəx ʕal az=zəfkar, ánnaqqa d-sōm mḥayḏ̣ar u=dahwayḏa w mḥayḏ̣ar u=flān bēhvanayḏa",
            "translations": [
              "er wird bei Goldschmieden herumgehen, um den Goldschmuck und die Siebensachen für sie bereitzumachen"
            ],
            "references": [
              "781",
              "65/139"
            ]
          },
          {
            "turoyo": "141; ya i=barṯ-ayḏi, mahelul-li yarḥo d-yawmoṯo, ḥatta də-mḥayḏ̣anno u=mede d-kit lazəm aʕmayxu",
            "translations": [
              "‘meine Tochter! Gebt mir einen Monat Frist, damit ich das, was ihr mitnehmen müsst, bereit mache!’;"
            ],
            "references": [
              "24/129"
            ]
          },
          {
            "turoyo": "m-oʕdo hul l-yarḥo gə-mḥaḏ̣al-lan gd-əzzano",
            "translations": [
              "‘von heute bis zum Ende eines Monats will er für uns vorbereitungen treffen; dann werden wir gehen’;"
            ],
            "references": [
              "24/131"
            ]
          }
        ],
        "Imperative": [
          {
            "turoyo": "ənkān lə=k-bat-li i=nuxrayt-ayḏi, ḥayḏ̣ár ruḥux bayn-eli w elux",
            "translations": [
              "wenn du meine Verlobte nicht gibst, so bereite dich (zum Kampf) zwischen mir und dir vor"
            ],
            "references": [
              "781",
              "62/16"
            ]
          },
          {
            "turoyo": "mʕayanlan yawmo, ummina: “flān yawmo, mḥayḏ̣ēr-e!”",
            "translations": [
              "wir setzten einen Tag fest und sagten:"
            ],
            "references": [
              "11/256"
            ]
          },
          {
            "turoyo": "ḥayḏ̣eru ruḥayxu l-i=qale!",
            "translations": [
              "‘macht euch zum Kampfe bereit!’;"
            ],
            "references": [
              "24/206"
            ]
          },
          {
            "turoyo": "mḥaḏ̣ə́r u=taḥḏ̣ir diḏux",
            "translations": [
              "‘bereite alles vor, (Papa)!’;"
            ],
            "references": [
              "28/77"
            ]
          }
        ]
      },
