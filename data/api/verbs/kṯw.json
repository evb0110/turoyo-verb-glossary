            "references": [
              "DD 393/13"
            ]
          }
        ],
        "Imperative": [
          {
            "turoyo": "kṯaw ṣurto xəd ṣurti, awbel-a aʕmox",
            "translations": [
              "zeichne dir mein Bild und nimm es mit"
            ],
            "references": [
              "277",
              "prs 98/28"
            ]
          },
          {
            "turoyo": "d-ŭwe-lox zaḥme mede kṯaw-li",
            "translations": [
              "wenn Sie irgend eine Schwierigkeit haben, so schreiben Sie mir"
            ],
            "references": [
              "5/8"
            ]
          }
        ],
        "Participle_Active": [
          {
            "turoyo": "u=kaṯowo",
            "translations": [
              "der Schreiber"
            ],
            "references": [
              "277"
            ]
          }
        ],
        "Infinitive": [
          {
            "turoyo": "yatuno qəm d-i=maṣa, d-kət-yo qəm d-u=šəbbak də-k-ḥoyər l-u=Boġāz; w bdeli b-u=kṯowo, xəd u=mede l-aloho d-malhámle-li",
            "translations": [
              "ich setzte mich an den Tisch, der am Fenster steht und nach dem Bosporus blickt, und fing an, etwas zu schreiben, wie es mir Gott eingab"
            ],
            "references": [
              "4/10"
            ]
          }
        ],
        "Participle_Passive": [
          {
            "turoyo": "aloho b-a=kṯowe kṯíwo-yo, d-kət-yo nuhro",
            "translations": [
              "in den Schriften steht geschrieben, dass Gott Licht ist"
            ],
            "references": [
              "279",
              "84/40"
            ]
          },
