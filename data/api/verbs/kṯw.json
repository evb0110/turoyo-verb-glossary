      "conjugations": {
        "Preterit": [
          {
            "turoyo": "ko-maqbanno i=tawr-ayo d-aloho kṯíwo-le w híwo-le l-Muše u=nabiyayḏe",
            "translations": [
              "ja, ich glaube an die Thora, die Gott schrieb und Moses, seinem Propheten, gab"
            ],
            "references": [
              "LB 89"
            ]
          }
        ],
        "Preterit-wa": [
          {
            "turoyo": "tamo mṣaḥáḥno-wo af=fišat d-u=luġat, də-kṯú-wo-lle l-ḥa=mʕalləm alamani, d-ŭḏáʕno-wo-le, w l-ḥa=xōrt, w afandi turk",
            "translations": [
              "dort sah ich auch die Zettel durch, die ein mir bekannter deutscher Lehrer und ein junger türkischer Herr geschrieben hatten"
            ],
            "references": [
