{
  "root": "fṣḥ",
  "etymology": {
    "source": "MEA",
    "source_root": "pṣḥ",
    "reference": "SL 1218",
    "meaning": "to rejoice"
  },
  "cross_reference": null,
  "stems": [
    {
      "forms": [
        "fṣīḥ",
        "məfṣəḥ"
      ],
      "conjugations": {
        "Preterit": [
          {
            "turoyo": "ġắlabe fṣəḥno d-kətno bwār d-u=bayt-awo",
            "translations": [
              "ich freute mich sehr, wie ich so gegenüber diesem Haus stand"
            ],
            "references": [
              "LB 240"
            ]
          },
          {
            "turoyo": "fṣəḥno l-i=mṯayt-aṯxu d-aṯutu b-xēr w-salame",
            "translations": [
              "ich habe mich über euer kommen gefreut, dass ihr gut und wohlbehalten heimgekommen seid"
            ],
            "references": [
              "19/1"
            ]
          },
          {
            "turoyo": "u=mṣaydono lát-wo-le abne heš. fṣiḥ buwe huwe w-i=aṯto ġálabe ‘",
            "translations": [
              "Denn der fiseher hatte noch keine Söhne, er und seine frau hatten an ihm große Freude"
            ],
            "references": [
              "23/28"
            ]
          },
          {
            "turoyo": "bəṯṯər d-məlle, d-šamiʕi hawxa u=ahl d-i=walaye, d-kit-yo ḥakimo hano, fṣiḥi ġálabe ‘",
            "translations": [
              "Als er so sprach und die Leute der Stadt hörten, daß er Arzt war, freuten sie sich sehr’"
            ],
            "references": [
              "24/57"
            ]
          },
          {
            "turoyo": "fṣəḥina ġálabe aʕmox",
            "translations": [
              "‘Wir haben uns so sehr über dich gefreut’; 29/278"
            ],
            "references": []
          }
        ],
        "Infectum": [
          {
            "turoyo": "ṭləble, mṣalele ġắlabe m-aloho, ḥatta d-aloho d-obe-le abro d-məfṣəḥ buwe",
            "translations": [
              "er bat und betete viel zu Gott, dass Gott ihm einen Sohn schenken möchte, an dem er seine Freude haben könnte"
            ],
            "references": [
              "129",
              "24/2"
            ]
          },
          {
            "turoyo": "[MT]aṯyo ḥeḏore ʕamar mə=kibux taw qum yətwina gəḥkina məfṣoḥina uxlina šotina",
            "translations": [],
            "references": []
          },
          {
            "turoyo": "‘She came close to him (and said):",
            "translations": [
              "ʕAmar, what’s wrong? Come, sit (with me). Let’s laugh and have fun, eat and drink!"
            ],
            "references": []
          }
        ],
        "Infectum-wa": [
          {
            "turoyo": "kul d-šumʕi-wo, məfṣəḥi-wo, w zaydi-wo",
            "translations": [
              "so oft sie sie hörten, freuten sie sich, und es wurden ihrer immer mehr"
            ],
            "references": [
              "132",
              "11/188"
            ]
          }
        ],
        "Imperative": [
          {
            "turoyo": "ya u=babayḏi, məfṣǝ́ḥ",
            "translations": [
              "Vater! Freue dich"
            ],
            "references": [
              "133",
              "24/122"
            ]
          },
          {
            "turoyo": "axúl, məfṣəḥ, štay həč lə-mikadrət! ‘",
            "translations": [
              "Iß, sei vergnügt, trinke, und sei durchaus nicht betrübt!’"
            ],
            "references": [
              "24/121",
              "[MT]"
            ]
          }
        ],
        "Nomen Patiens": [
          {
            "turoyo": "fṣiḥoyo",
            "translations": [
              "fröhlich"
            ],
            "references": [
              "134"
            ]
          }
        ]
      },
